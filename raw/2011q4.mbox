rootfunc <- function(t,y,p) {
	if( length(EventQueue) == 0)
		stop()
	else
		return min(t-EventQueue$t)
}

eventfunc <- function(t,y,p) {
	# Execute event
	[...]
	# Remove event from event queue
	[...]

	return(y)
}

lsoda(
	y=y,
	times=c(0, 1e8),
	func=Model,
	parms=parms,
	events=list(func=eventfunc, root=TRUE),
	rootfunc=rootfunc
)


