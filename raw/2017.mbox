# Data --------------------------------------------------------------------


## Import data from file and place them onto a data.frame
Data12 <- data.frame(cbind(A12_full$tmes2, A12_full$Xmes12, A12_full$NO3mes12, A12_full$QNmes12))


## Retrieve parameters from file
