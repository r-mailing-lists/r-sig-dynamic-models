          PG <- 0.2) # rate of half transformation in Stomach

 advModel <- function(t, state, parms) {

     with (as.list(parms), {
         Stomach1 <- state[1]  # undisintegrated
         Stomach2 <- state[2]   # granule
         Stomach3 <- state[3]   # Precipitate
         Stomach4 <- state[4]   # dissolved
