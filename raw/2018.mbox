library(deSolve)
library(ReacTran)

## The model equations
SEIR2D <- function (t, y, parms)  {
  S  <- matrix(y[1:N^2], N, N)
  E  <- matrix(y[(N^2 + 1):(2*N^2)], N, N)
  I  <- matrix(y[(2*N^2 + 1):(3*N^2)], N, N)
  R  <- matrix(y[(3*(N^2) + 1):(4*N^2)], N, N)

  infect <- beta * I * S
  recovr <- nu * I

  dS <- -infect + tran.2D(S, dx = dx, dy = dy, D.x = D1, D.y = D1)$dC
